<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:app="http://schemas.android.com/apk/res-auto">

        <PreferenceCategory app:title="@string/category_options">
                <ListPreference
                    app:defaultValue="@string/overlay_auto_hide_default"
                    app:entries="@array/overlay_auto_hide_entries"
                    app:entryValues="@array/overlay_auto_hide_values"
                    app:key="overlay_auto_hide"
                    app:title="@string/appearance_auto_hide_title"
                    app:useSimpleSummaryProvider="true" />

                <ListPreference
                    app:defaultValue="@string/overlay_reveal_timeout_default"
                    app:entries="@array/overlay_reveal_timeout_entries"
                    app:entryValues="@array/overlay_reveal_timeout_values"
                    app:key="overlay_reveal_timeout"
                    app:title="@string/appearance_reveal_for_title"
                    app:useSimpleSummaryProvider="true" />

                <MultiSelectListPreference
                    app:defaultValue="@array/overlay_fade_corners_default"
                    app:entries="@array/overlay_fade_corners_entries"
                    app:entryValues="@array/overlay_fade_corners_values"
                    app:key="overlay_fade_corners_selection"
                    app:title="@string/appearance_fade_corners_title"
                    app:dialogTitle="@string/appearance_fade_corners_title" />
        </PreferenceCategory>
</PreferenceScreen>
