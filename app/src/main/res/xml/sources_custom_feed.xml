<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:app="http://schemas.android.com/apk/res-auto">

        <PreferenceCategory app:title="@string/category_video_source">
                <SwitchPreference
                    app:defaultValue="false"
                    app:key="custom_media_enabled"
                    app:title="@string/custom_media_enabled" />
        </PreferenceCategory>

        <PreferenceCategory app:title="@string/category_feed_and_stream_details">
                <Preference
                    app:selectable="false"
                    app:summary="@string/custom_media_feeds_notice" />

                <EditTextPreference
                    app:dependency="custom_media_enabled"
                    app:disableDependentsState="false"
                    app:key="custom_media_urls"
                    app:title="@string/custom_media_urls_title"
                    app:summary="@string/custom_media_urls_summary" />
        </PreferenceCategory>

        <PreferenceCategory app:title="@string/category_quality">
                <ListPreference
                    app:dependency="custom_media_enabled"
                    app:disableDependentsState="false"
                    app:defaultValue="@string/custom_feed_quality_default"
                    app:entries="@array/custom_feed_quality_entries"
                    app:entryValues="@array/custom_feed_quality_values"
                    app:key="custom_media_quality"
                    app:title="@string/videos_quality_title"
                    app:useSimpleSummaryProvider="true"
                    app:dialogTitle="@string/videos_quality_summary" />
        </PreferenceCategory>
</PreferenceScreen>
