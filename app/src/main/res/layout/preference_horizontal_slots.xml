<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp">

    <!-- Left Column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="8dp">

        <!-- Left Category Title -->
        <TextView
            android:id="@+id/left_category_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:text="@string/category_top_row_left"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:textStyle="bold" />

        <!-- Left Slot 2 -->
        <LinearLayout
            android:id="@+id/left_slot2_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/left_slot2_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appearance_slot2_title"
                android:textAppearance="?android:attr/textAppearanceMedium" />

            <TextView
                android:id="@+id/left_slot2_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appearance_slot_summary"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:attr/textColorSecondary" />
        </LinearLayout>

        <!-- Left Slot 1 -->
        <LinearLayout
            android:id="@+id/left_slot1_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/left_slot1_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appearance_slot1_title"
                android:textAppearance="?android:attr/textAppearanceMedium" />

            <TextView
                android:id="@+id/left_slot1_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appearance_slot_summary"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:attr/textColorSecondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="?android:attr/dividerVertical"
        android:layout_marginVertical="8dp" />

    <!-- Right Column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp">

        <!-- Right Category Title -->
        <TextView
            android:id="@+id/right_category_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:text="@string/category_top_row_right"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:textStyle="bold" />

        <!-- Right Slot 2 -->
        <LinearLayout
            android:id="@+id/right_slot2_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/right_slot2_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appearance_slot2_title"
                android:textAppearance="?android:attr/textAppearanceMedium" />

            <TextView
                android:id="@+id/right_slot2_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appearance_slot_summary"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:attr/textColorSecondary" />
        </LinearLayout>

        <!-- Right Slot 1 -->
        <LinearLayout
            android:id="@+id/right_slot1_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/right_slot1_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appearance_slot1_title"
                android:textAppearance="?android:attr/textAppearanceMedium" />

            <TextView
                android:id="@+id/right_slot1_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appearance_slot_summary"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:attr/textColorSecondary" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
